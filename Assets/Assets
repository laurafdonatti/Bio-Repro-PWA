  <script>
  // ---- Crossword layout (game logic, not editable content) ----
  // Grid coordinates: row (r), col (c). Answers store normalized (no accents, uppercase).
  const words = [
    { num:1, dir:'across', answer:'GAMETAS',     r:0,  c:0 },
    { num:2, dir:'across', answer:'UTERO',       r:2,  c:2 },
    { num:3, dir:'across', answer:'PROSTATA',    r:4,  c:1 },
    { num:4, dir:'across', answer:'TESTICULO',   r:6,  c:0 },
    { num:5, dir:'down',   answer:'OVARIO',      r:0,  c:2 },
    { num:6, dir:'down',   answer:'PRESERVATIVO',r:0,  c:6 },
    { num:7, dir:'down',   answer:'VACINACAO',   r:2,  c:4 },
    { num:8, dir:'down',   answer:'PREVENCAO',   r:4,  c:1 }
  ];

  const grid = document.getElementById('crossword-grid');
  const feedback = document.getElementById('feedback-banner');
  const positiveMessages = ['Muito bem! 👏','Ótimo, continue assim! 🌟','Você está aprendendo! 💚','Excelente! ✨'];

  let cellMap = {}; // "r,c" -> { input, answer }
  let muted = false;

  // Compute grid bounds
  function cellsForWord(w){
    const arr = [];
    for(let i=0;i<w.answer.length;i++){
      const r = w.dir==='across' ? w.r : w.r+i;
      const c = w.dir==='across' ? w.c+i : w.c;
      arr.push({ r, c, ch: w.answer[i] });
    }
    return arr;
  }

  function buildGrid(){
    grid.innerHTML = '';
    cellMap = {};
    const active = {};   // "r,c" -> letter
    const numbers = {};  // "r,c" -> number
    let maxR = 0, maxC = 0;

    words.forEach(w=>{
      cellsForWord(w).forEach((cell, idx)=>{
        const key = cell.r + ',' + cell.c;
        active[key] = cell.ch;
        maxR = Math.max(maxR, cell.r);
        maxC = Math.max(maxC, cell.c);
        if(idx===0 && !numbers[key]) numbers[key] = w.num;
      });
    });

    grid.style.gridTemplateColumns = 'repeat(' + (maxC+1) + ', min-content)';

    for(let r=0; r<=maxR; r++){
      for(let c=0; c<=maxC; c++){
        const key = r + ',' + c;
        const cellDiv = document.createElement('div');
        cellDiv.className = 'cw-cell';
        if(active[key]){
          const input = document.createElement('input');
          input.type = 'text';
          input.maxLength = 1;
          input.className = 'cw-input';
          input.setAttribute('inputmode','text');
          input.setAttribute('autocomplete','off');
          input.setAttribute('aria-label', 'Letra na linha ' + (r+1) + ', coluna ' + (c+1));
          input.dataset.r = r;
          input.dataset.c = c;
          input.addEventListener('input', onType);
          input.addEventListener('keydown', onKey);
          cellDiv.appendChild(input);
          if(numbers[key]){
            const num = document.createElement('span');
            num.className = 'cw-num';
            num.textContent = numbers[key];
            cellDiv.appendChild(num);
          }
          cellMap[key] = { input, answer: active[key] };
        } else {
          cellDiv.classList.add('cw-empty');
        }
        grid.appendChild(cellDiv);
      }
    }
  }

  function focusCell(r, c){
    const cell = cellMap[r + ',' + c];
    if(cell) cell.input.focus();
  }

  function onType(e){
    const el = e.target;
    el.value = el.value.toUpperCase().replace(/[^A-ZÇÁÀÂÃÉÊÍÓÔÕÚ]/gi, '').slice(0,1);
    el.classList.remove('correct','wrong');
    if(el.value){
      playClick();
      const r = +el.dataset.r, c = +el.dataset.c;
      // advance right, then down as fallback
      if(cellMap[r + ',' + (c+1)]) focusCell(r, c+1);
      else if(cellMap[(r+1) + ',' + c]) focusCell(r+1, c);
    }
  }

  function onKey(e){
    const el = e.target;
    const r = +el.dataset.r, c = +el.dataset.c;
    if(e.key==='Backspace' && !el.value){
      if(cellMap[r + ',' + (c-1)]){ e.preventDefault(); focusCell(r, c-1); }
      else if(cellMap[(r-1) + ',' + c]){ e.preventDefault(); focusCell(r-1, c); }
    } else if(e.key==='ArrowRight'){ e.preventDefault(); focusCell(r, c+1); }
    else if(e.key==='ArrowLeft'){ e.preventDefault(); focusCell(r, c-1); }
    else if(e.key==='ArrowDown'){ e.preventDefault(); focusCell(r+1, c); }
    else if(e.key==='ArrowUp'){ e.preventDefault(); focusCell(r-1, c); }
  }

  function normalize(s){
    return s.toUpperCase().normalize('NFD').replace(/[\u0300-\u036f]/g,'').replace(/Ç/g,'C');
  }

  function checkAnswers(){
    initAudio();
    let filled = 0, correct = 0, total = 0;
    Object.values(cellMap).forEach(({input, answer})=>{
      total++;
      const val = normalize(input.value.trim());
      const ans = normalize(answer);
      input.classList.remove('correct','wrong');
      if(val){
        filled++;
        if(val === ans){ input.classList.add('correct'); correct++; }
        else { input.classList.add('wrong'); }
      }
    });

    if(correct === total){
      showFeedback('🎉 Parabéns! Você completou tudo corretamente. Cuidar da saúde reprodutiva é um ato de respeito e prevenção!', true);
      playVictory();
    } else if(filled === 0){
      showFeedback('✏️ Preencha as letras usando as dicas ao lado. Não há tempo: aprenda com calma!', false);
    } else {
      const msg = positiveMessages[Math.floor(Math.random()*positiveMessages.length)];
      showFeedback(msg + ' Você acertou ' + correct + ' de ' + total + ' letras. As em verde estão certas — continue!', false);
      playSuccess();
    }
  }

  function showFeedback(msg, win){
    feedback.textContent = msg;
    feedback.classList.remove('hidden');
    feedback.classList.add('pop');
    setTimeout(()=>feedback.classList.remove('pop'), 400);
  }

  function restart(){
    Object.values(cellMap).forEach(({input})=>{
      input.value = '';
      input.classList.remove('correct','wrong');
    });
    feedback.classList.add('hidden');
    feedback.textContent = '';
    focusCell(0,0);
  }

  document.getElementById('btn-check').addEventListener('click', checkAnswers);
  document.getElementById('btn-restart').addEventListener('click', ()=>{ initAudio(); restart(); });

  // ---- Accessibility ----
  let scale = 1.1;
  const applyScale = ()=>document.documentElement.style.setProperty('--font-scale', scale);
  document.getElementById('btn-font-inc').addEventListener('click', ()=>{ scale=Math.min(1.7,scale+0.1); applyScale(); });
  document.getElementById('btn-font-dec').addEventListener('click', ()=>{ scale=Math.max(0.9,scale-0.1); applyScale(); });
  document.getElementById('btn-contrast').addEventListener('click', (e)=>{ const on=document.body.classList.toggle('contrast'); e.currentTarget.setAttribute('aria-pressed',on); });
  document.getElementById('btn-dark').addEventListener('click', (e)=>{ const on=document.body.classList.toggle('dark'); e.currentTarget.setAttribute('aria-pressed',on); });
  document.getElementById('btn-mute').addEventListener('click', (e)=>{ muted=!muted; e.currentTarget.setAttribute('aria-pressed',muted); });

  // ---- Web Audio ----
  let actx=null;
  function initAudio(){ if(!actx){ try{ actx=new (window.AudioContext||window.webkitAudioContext)(); }catch(e){} } if(actx&&actx.state==='suspended') actx.resume(); }
  function tone(freq,dur,type='sine',vol=0.15){
    if(muted||!actx) return;
    const o=actx.createOscillator(), g=actx.createGain();
    o.type=type; o.frequency.value=freq;
    o.connect(g); g.connect(actx.destination);
    const t=actx.currentTime;
    g.gain.setValueAtTime(0,t); g.gain.linearRampToValueAtTime(vol,t+0.02);
    g.gain.exponentialRampToValueAtTime(0.001,t+dur);
    o.start(t); o.stop(t+dur);
  }
  function playClick(){ tone(440,0.06,'triangle',0.08); }
  function playSuccess(){ tone(660,0.12,'sine'); setTimeout(()=>tone(880,0.16,'sine'),110); }
  function playVictory(){ [523,659,784,1046].forEach((f,i)=>setTimeout(()=>tone(f,0.25,'sine'),i*150)); }

  buildGrid();
  lucide.createIcons();
</script>
